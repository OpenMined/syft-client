# Print the VM's external IP
[group('inspect')]
get-ip name=vm_default: _whoami
    #!/bin/bash
    set -e
    {{load_settings}}
    gcloud compute instances describe {{name}} \
      --project="$project_id" \
      --zone="$zone" \
      --format='get(networkInterfaces[0].accessConfigs[0].natIP)'

